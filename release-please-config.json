{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore: release",
  "packages": {
    "sdks/js": {
      "release-type": "node",
      "component": "@cntm-labs/nucleus-js",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/node": {
      "release-type": "node",
      "component": "@cntm-labs/nucleus-node",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/react": {
      "release-type": "node",
      "component": "@cntm-labs/nucleus-react",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/nextjs": {
      "release-type": "node",
      "component": "@cntm-labs/nucleus-nextjs",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/python": {
      "release-type": "python",
      "component": "cntm-nucleus-python",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/rust": {
      "release-type": "rust",
      "component": "cntm-nucleus",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/flutter": {
      "release-type": "dart",
      "component": "cntm-nucleus-flutter",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/dotnet": {
      "release-type": "simple",
      "component": "Cntm.Nucleus",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/java": {
      "release-type": "maven",
      "component": "cntm-nucleus-java",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/android": {
      "release-type": "simple",
      "component": "cntm-nucleus-android",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/android-java": {
      "release-type": "simple",
      "component": "cntm-nucleus-android-java",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/swift": {
      "release-type": "simple",
      "component": "CntmNucleus",
      "changelog-path": "CHANGELOG.md"
    },
    "sdks/go": {
      "release-type": "go",
      "component": "cntm-nucleus-go",
      "changelog-path": "CHANGELOG.md"
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "nucleus",
      "components": [
        "@cntm-labs/nucleus-js",
        "@cntm-labs/nucleus-node",
        "@cntm-labs/nucleus-react",
        "@cntm-labs/nucleus-nextjs",
        "cntm-nucleus-python",
        "cntm-nucleus",
        "cntm-nucleus-flutter",
        "Cntm.Nucleus",
        "cntm-nucleus-java",
        "cntm-nucleus-android",
        "cntm-nucleus-android-java",
        "CntmNucleus",
        "cntm-nucleus-go"
      ]
    }
  ]
}
