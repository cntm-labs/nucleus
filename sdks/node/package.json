{
  "name": "@cntm-labs/node",
  "version": "0.2.0",
  "description": "Nucleus authentication SDK for Node.js.",
  "keywords": [
    "authentication",
    "auth",
    "nucleus",
    "sdk",
    "node",
    "express",
    "fastify"
  ],
  "license": "MIT",
  "author": "cntm-labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/cntm-labs/nucleus.git",
    "directory": "sdks/node"
  },
  "homepage": "https://github.com/cntm-labs/nucleus",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/esm/express.js",
      "require": "./dist/cjs/express.js",
      "types": "./dist/express.d.ts"
    },
    "./fastify": {
      "import": "./dist/esm/fastify.js",
      "require": "./dist/cjs/fastify.js",
      "types": "./dist/fastify.d.ts"
    },
    "./hono": {
      "import": "./dist/esm/hono.js",
      "require": "./dist/cjs/hono.js",
      "types": "./dist/hono.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jose": "^5.0.0"
  },
  "peerDependencies": {
    "express": ">=4",
    "fastify": ">=4",
    "hono": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "~5.7.0",
    "tsup": "^8.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
