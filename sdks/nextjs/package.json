{
  "name": "@nucleus/nextjs",
  "version": "0.1.0",
  "description": "Nucleus authentication SDK for Next.js",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/esm/index.js", "require": "./dist/cjs/index.js", "types": "./dist/index.d.ts" },
    "./server": { "import": "./dist/esm/server/index.js", "require": "./dist/cjs/server/index.js", "types": "./dist/server/index.d.ts" }
  },
  "files": ["dist"],
  "scripts": { "build": "tsup", "typecheck": "tsc --noEmit" },
  "dependencies": { "jose": "^5.0.0" },
  "peerDependencies": { "react": ">=18", "react-dom": ">=18", "next": ">=14" },
  "devDependencies": { "typescript": "~5.7.0", "tsup": "^8.0.0", "react": "^19.0.0", "react-dom": "^19.0.0", "@types/react": "^19.0.0", "next": "^15.0.0" }
}
