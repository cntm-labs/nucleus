{
  "name": "@cntm-labs/nextjs",
  "version": "0.1.0-dev.1",
  "description": "DEV PREVIEW — Not ready for production. Nucleus authentication SDK for Next.js.",
  "license": "MIT",
  "author": "cntm-labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/cntm-labs/nucleus.git",
    "directory": "sdks/nextjs"
  },
  "homepage": "https://github.com/cntm-labs/nucleus",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/esm/server/index.js",
      "require": "./dist/cjs/server/index.js",
      "types": "./dist/server/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "jose": "^5.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "jsdom": "^24.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
