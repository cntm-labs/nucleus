{
  "name": "@cntm-labs/nucleus-js",
  "version": "0.2.0",
  "description": "Nucleus authentication SDK for JavaScript.",
  "keywords": [
    "authentication",
    "auth",
    "nucleus",
    "sdk",
    "jwt",
    "oauth"
  ],
  "license": "MIT",
  "author": "cntm-labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/cntm-labs/nucleus.git",
    "directory": "sdks/js"
  },
  "homepage": "https://github.com/cntm-labs/nucleus",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jose": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
