DATABASE_URL=postgres://nucleus:nucleus@localhost:5432/nucleus
REDIS_URL=redis://localhost:6379
MASTER_ENCRYPTION_KEY=change-me-in-production-64-hex-chars
HOST=0.0.0.0
PORT=3000
RUST_LOG=nucleus=debug,tower_http=debug
ALLOWED_ORIGINS=http://localhost:3001,https://app.example.com

# JWT / Issuer
ISSUER_URL=https://nucleus.local
JWT_LIFETIME_SECS=300

# WebAuthn Relying Party
RP_NAME=Nucleus
RP_ID=localhost

# Rate Limiting
RATE_LIMIT_AUTH_MAX=60
RATE_LIMIT_AUTH_WINDOW_SECS=60
RATE_LIMIT_API_MAX=1000
RATE_LIMIT_API_WINDOW_SECS=60
