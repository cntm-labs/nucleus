{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Virtual Users (VUs)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "query": "SELECT mean(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval)", "alias": "VUs" }
      ]
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "query": "SELECT sum(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval)", "alias": "Requests/s" }
      ]
    },
    {
      "title": "Response Time (p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval)", "alias": "p95" },
        { "query": "SELECT percentile(\"value\", 99) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval)", "alias": "p99" }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "query": "SELECT sum(\"value\") FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval)", "alias": "Failed Requests" }
      ]
    },
    {
      "title": "Sign-In Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "query": "SELECT percentile(\"value\", 95) FROM \"sign_in_latency\" WHERE $timeFilter GROUP BY time($__interval)", "alias": "p95" }
      ]
    },
    {
      "title": "Token Refresh Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "query": "SELECT percentile(\"value\", 95) FROM \"token_refresh_latency\" WHERE $timeFilter GROUP BY time($__interval)", "alias": "p95" }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["nucleus", "k6", "load-test"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Nucleus - k6 Load Test Results",
  "uid": "nucleus-k6-dashboard",
  "version": 1
}
